# Local environment template. Copy to .env and fill real values; .env is git-ignored.

# Backend: Bailian/DashScope.
# BAILIAN_CALL_MODE=app uses /api/v1/apps/{APP_ID}/completion.
# BAILIAN_CALL_MODE=compatible uses /compatible-mode/v1/chat/completions.
BAILIAN_CALL_MODE=app
DASHSCOPE_HTTP_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_APP_ID=d77d3dffe51447ecb6d3d34e7a779560
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_API_KEY=
BAILIAN_CONNECT_TIMEOUT_MS=10000
BAILIAN_READ_TIMEOUT_MS=30000

# Legacy-compatible names. They are used only when the DASHSCOPE_* value is absent.
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/api/v1
BAILIAN_COMPATIBLE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_APP_ID=d77d3dffe51447ecb6d3d34e7a779560
BAILIAN_MODEL=qwen-plus
BAILIAN_API_KEY=

# Frontend: backend API address. Vite exposes only variables with VITE_ prefix.
VITE_API_BASE_URL=http://localhost:8080

# Frontend: AMap key, if online maps are needed.
VITE_AMAP_KEY=

# Backend: PostgreSQL connection, enabled when running with the postgres profile.
SPRING_PROFILES_ACTIVE=postgres
TRAFFIC_DB_HOST=localhost
TRAFFIC_DB_PORT=5432
TRAFFIC_DB_NAME=traffic_signal
TRAFFIC_DB_USERNAME=postgres
TRAFFIC_DB_PASSWORD=
