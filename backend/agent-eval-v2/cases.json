    {
      "id": "LANG-001",
      "category": "语言规范化",
      "question": "请先检索项目知识库，再用简洁、正式的中文解释 MaxPressure 与 FixedTime 的区别，交通专业术语保留英文名称，列出三个要点并以知识库内容为依据。",
      "expect": {
        "intentAnyOf": ["knowledge"],
        "toolAnyOf": ["search_knowledge_base"],
        "requiredToolStatus": "SUCCESS",
        "requireEvidenceOnToolSuccess": true,
        "replyContainsAll": ["MaxPressure", "FixedTime"],
        "requireChinese": true,
        "requireMarkdownList": true,
        "maxReplyChars": 1800
      }
    },
    {
      "id": "FORMAT-001",
      "category": "输出格式",
      "question": "说明 Traffic-R、安全层和 fallback 的关系。先给一句结论，再用 Markdown 列表给出至少三个关键点。只输出面向用户的最终回答。",
      "expect": {
        "intentAnyOf": ["knowledge"],
        "toolAnyOf": ["search_knowledge_base"],
        "requiredToolStatus": "SUCCESS",
        "replyContainsAny": ["Traffic-R", "安全层", "fallback"],
        "requireChinese": true,
        "requireMarkdownList": true,
        "forbidJsonReply": true,
        "forbidCodeFence": true
      }
    },
    {
      "id": "LANG-002",
      "category": "语言规范化",
      "question": "pls 帮我瞅瞅 backend、CityFlow 和 model service 现在咋样；请规范成正式中文回答，不要输出 JSON。",
      "expect": {
        "intentAnyOf": ["system_health"],
        "toolAnyOf": ["get_system_health"],
        "requiredToolStatus": "SUCCESS",
        "requireEvidenceOnToolSuccess": true,
        "requireAuditIds": true,
        "replyContainsAny": ["系统", "服务", "健康", "状态"],
        "requireChinese": true,
        "forbidJsonReply": true,
        "forbidCodeFence": true,
        "maxReplyChars": 1600
      }
