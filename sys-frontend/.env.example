# ================================================================
# 本地私密配置 — 使用前请复制本文件为 .env 并填入真实 Key
#   cp sys-frontend/.env.example sys-frontend/.env
# ================================================================

# ---- 后端 API 地址 ----
VITE_API_BASE_URL=http://localhost:8080

# ---- 高德地图 Key（https://console.amap.com/dev/key/app 申请）----
# JS API v2 Key（地图加载）
VITE_AMAP_KEY=your_amap_key_here
# Web 服务 Key（POI 搜索 + 路径规划，可与 JS API Key 相同）
VITE_AMAP_WEB_KEY=your_amap_web_key_here

# ---- 智能体说明 ----
# 前端不再直连百炼/DashScope Agent 应用，也不需要配置模型 API Key。
# 统一调用 Spring Boot 后端 `/api/v1/agent/chat`，模型、工具和知识库检索配置由后端管理。
