# ================================================================
# 本地私密配置 — 使用前请复制本文件为 .env 并填入真实 Key
#   cp sys-frontend/.env.example sys-frontend/.env
# ================================================================

# ---- 后端 API 地址 ----
VITE_API_BASE_URL=http://localhost:8080

# ---- 高德地图 Key（https://console.amap.com/dev/key/app 申请）----
# JS API v2 Key（地图加载）
VITE_AMAP_KEY=your_amap_key_here
# Web 服务 Key（POI 搜索 + 路径规划，可与 JS API Key 相同）
VITE_AMAP_WEB_KEY=your_amap_web_key_here

# ---- 百炼 / DashScope 智能体 ----
BAILIAN_CALL_MODE=compatible
DASHSCOPE_HTTP_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_COMPATIBLE_BASE_URL=https://your-instance.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_APP_ID=your_dashscope_app_id
DASHSCOPE_API_KEY=your_dashscope_api_key
