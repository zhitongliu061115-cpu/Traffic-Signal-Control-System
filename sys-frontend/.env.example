# ================================================================
# 高德地图 API Key — 使用前请复制本文件为 .env 并填入真实 Key
# cp sys-frontend/.env.example sys-frontend/.env
# ================================================================
# 高德 JS API v2 Key（用于地图加载）→ https://console.amap.com/dev/key/app
VITE_AMAP_KEY=your_amap_key_here
# 高德 Web 服务 Key（用于 POI 搜索 + 路径规划，可与 JS API Key 相同）
VITE_AMAP_WEB_KEY=your_amap_web_key_here
